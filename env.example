# ============================================================================
# Gate Intelligence Engine Backend — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================

DB_HOST=localhost
DB_PORT=5432
DB_NAME=gate_intelligence
DB_USER=postgres
DB_PASSWORD=change_me_in_production
DB_SSL=false

# ============================================================================
# REDIS (Caching & Session Storage)
# ============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================================================
# GEMINI API (Wait Time Forecasting)
# ============================================================================

# Get key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ============================================================================
# CORS & SECURITY
# ============================================================================

# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# JWT Secret for API authentication (generate with: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_here

# Require authentication (disable for demo/development)
REQUIRE_AUTH=false

# ============================================================================
# RATE LIMITING
# ============================================================================

# Time window in milliseconds
RATE_LIMIT_WINDOW_MS=900000

# Max requests per window
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# VENUE CONFIGURATION
# ============================================================================

# Default venue ID (used if not specified in requests)
DEFAULT_VENUE_ID=stadiumA

# Gate IDs (comma-separated)
DEFAULT_GATES=gate_1,gate_2,gate_3,gate_4,gate_5,gate_6,gate_7,gate_8

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================

# Sentry error tracking (optional)
SENTRY_DSN=

# DataDog API key (optional)
DATADOG_API_KEY=

# ============================================================================
# FEATURE FLAGS (Development)
# ============================================================================

# Enable Gemini API (set false to use rule-based forecasting only)
ENABLE_GEMINI_FORECASTING=true

# Enable WebSocket broadcasting
ENABLE_WEBSOCKET=true

# Enable scheduled jobs (aggregation, calibration)
ENABLE_SCHEDULED_JOBS=true

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================

# Seed demo data on startup
SEED_DEMO_DATA=true

# Mock incident replay (for testing baseline comparison)
MOCK_INCIDENT_REPLAY=false

# Verbose request logging
VERBOSE_LOGGING=false
